# Twilio Credentials
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Target Outbound Number (for testing)
OUTBOUND_PHONE_NUMBER=+1987654321

# Server Settings
PORT=8000
HOST=0.0.0.0

# Base URL of this server (used by Twilio to send Webhook / TwiML responses)
# For local development, this is typically your Ngrok or LocalTunnel URL
SERVER_URL=https://your-ngrok-subdomain.ngrok-free.app

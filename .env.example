# Twilio Credentials
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Target Outbound Number (for testing)
OUTBOUND_PHONE_NUMBER=+1987654321

# Server Settings
PORT=8000
HOST=0.0.0.0

# Base URL of this server (used by Twilio to send Webhook / TwiML responses)
# For local development, this is typically your Ngrok or LocalTunnel URL
SERVER_URL=https://your-ngrok-subdomain.ngrok-free.app

# Browser origins allowed to call this API (the Guardian Webapp is a separate origin).
# Comma-separated, or "*" to allow any. For local dev the webapp runs on :3000.
# e.g. CORS_ALLOW_ORIGINS=http://localhost:3000,https://your-webapp-domain
CORS_ALLOW_ORIGINS=*

# Gemini / Vision (image verification pipeline)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.5-flash
# Min AI confidence (0.0-1.0) required to verify structural damage.
VISION_CONFIDENCE_THRESHOLD=0.80
